# SQLite database (path is relative to the prisma/ directory)
DATABASE_URL="file:./dev.db"
# Change this in production
JWT_SECRET="dev-secret-change-me"
PORT=3021

# --- OTP delivery (optional) ---------------------------------------------
# With none of these set, login codes are printed to this server's terminal.
# Email codes via Resend (free tier: https://resend.com):
# RESEND_API_KEY=re_xxxxxxxx
# OTP_EMAIL_FROM="TeamCollab <login@yourdomain.com>"
# Real SMS codes via Twilio (https://twilio.com):
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM=+15551234567
